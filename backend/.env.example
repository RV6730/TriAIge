# backend/.env.example — Copy to .env and fill in your keys
# NEVER commit .env to version control

# ── Sarvam AI (Hindi/Tamil/Telugu STT) ──────────────────────────────────────
# Sign up at: https://www.sarvam.ai/dashboard  (free tier available)
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Twilio WhatsApp Sandbox ──────────────────────────────────────────────────
# Sign up at: https://console.twilio.com  (free)
# WhatsApp Sandbox: Messaging → Try it out → Send a WhatsApp message
# Family member must first send "join <sandbox-keyword>" to +14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ── Demo phone (must have joined WhatsApp sandbox) ───────────────────────────
DEMO_FAMILY_PHONE=+919876543210
